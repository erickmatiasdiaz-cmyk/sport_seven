# App en serverless (Vercel): usa el POOLER de Supabase (puerto 6543, pgbouncer)
# para no agotar conexiones bajo concurrencia. Usa la conexion DIRECTA (5432)
# solo para migraciones via DIRECT_URL.
DATABASE_URL="postgresql://postgres.krxawudnypjazsqwswel:[PASSWORD]@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.krxawudnypjazsqwswel.supabase.co:5432/postgres"
AUTH_SECRET="change-me-to-a-long-random-secret"
ENABLE_BOOTSTRAP_DATA="false"
ENABLE_PUBLIC_REGISTRATION="true"
BOOTSTRAP_ADMIN_EMAIL=""
BOOTSTRAP_ADMIN_PASSWORD=""
NEXT_PUBLIC_APP_URL="https://tu-dominio.vercel.app"
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=""
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""
MERCADOPAGO_SANDBOX="false"
MERCADOPAGO_TEST_PAYER_EMAIL=""
PAYMENT_MODE="full"
RESERVATION_DEPOSIT_AMOUNT="5000"
PAYMENT_HOLD_MINUTES="5"
# Protege el endpoint de cron /api/cron/expire-reservations. Vercel Cron envia
# este valor como "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=""
